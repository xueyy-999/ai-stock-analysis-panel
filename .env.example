PORT=3000

# OpenAI-compatible chat completions endpoint.
# Local CPAMC example:
# LLM_API_URL=http://127.0.0.1:8317/api/provider/codex/v1/chat/completions
# LLM_MODEL=gpt-5.4
# Render deployment example:
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o-mini

# Use only for local UI testing without calling a real LLM.
LLM_MOCK=false

# Supabase REST credentials. Use Secret key/service_role on the server side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# Optional browser CORS restriction for deployed environments.
CORS_ORIGIN=*
